---
import Container from "@shared/ui/Container.astro";
import { useTranslations, ui } from "@shared/i18n";

interface Props {
    lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as keyof typeof ui);
const items = (ui[lang as keyof typeof ui] as any)["experience.items"] as any[];
---

<section
    id="work"
    class="opacity-0 translate-y-[30px] transition-all duration-700 ease-[cubic-bezier(0.5,0,0,1)] reveal-on-scroll @container mb-48"
>
    <Container>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
            <div class="md:col-span-4">
                <h2
                    class="text-sm font-bold uppercase tracking-widest text-gray-400 sticky top-32 font-mono scroll-spy-title"
                    data-section="work"
                >
                    {t("experience.label")}
                </h2>
            </div>

            <div class="md:col-span-8">
                <p
                    class="text-lg text-neutral-600 dark:text-neutral-400 leading-relaxed mb-12"
                >
                    {t("experience.intro")}
                </p>

                <div
                    class="flex justify-between items-end border-b border-black/10 dark:border-white/10 pb-4 mb-0"
                >
                    <span class="text-xs font-mono text-neutral-400">
                        {t("experience.log")}
                    </span>
                    <span class="text-xs font-mono text-neutral-400">
                        {t("experience.history")}
                    </span>
                </div>

                <div class="flex flex-col">
                    {
                        items.map((exp: any) => (
                            <div class="group py-12 border-b border-black/10 dark:border-white/10 -mx-6 px-6 transition-colors">
                                <div class="grid grid-cols-1 md:grid-cols-12 gap-y-4 md:gap-x-8 items-baseline">
                                    <div class="md:col-span-3">
                                        <span class="font-mono text-xs text-neutral-400 uppercase tracking-widest group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                                            {exp.period}
                                        </span>
                                    </div>

                                    <div class="md:col-span-9">
                                        <div class="flex justify-between items-start mb-2">
                                            <div>
                                                <h3 class="text-3xl font-bold text-neutral-900 dark:text-white transition-colors">
                                                    {exp.role}
                                                </h3>
                                                <p class="text-lg text-neutral-500 mt-1 font-medium transition-colors">
                                                    {exp.company}
                                                </p>
                                            </div>
                                        </div>

                                        <div class="flex flex-wrap gap-2 mt-4">
                                            {/* {exp.data.tags?.map((tag: string) => (
                                            <span class="px-2 py-1 border border-neutral-200 dark:border-neutral-800 rounded text-[10px] font-mono text-neutral-500 uppercase tracking-wider">
                                                {tag}
                                            </span>
                                        ))} */}
                                        </div>

                                        <div class="pt-8 text-neutral-600 dark:text-neutral-400 text-lg leading-relaxed space-y-4 transition-colors">
                                            <p>{exp.summary}</p>
                                            {exp.details && (
                                                <ul class="list-disc list-inside text-base space-y-2 marker:text-indigo-500 dark:marker:text-indigo-400">
                                                    {exp.details.map(
                                                        (detail: string) => (
                                                            <li>{detail}</li>
                                                        ),
                                                    )}
                                                </ul>
                                            )}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>

                <div class="mt-12 flex justify-end">
                    <a
                        href={t("experience.cv_file") as string}
                        download
                        class="group inline-flex items-center gap-3 text-sm font-bold uppercase tracking-widest text-neutral-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors"
                    >
                        <span
                            class="border-b-2 border-black dark:border-white group-hover:border-indigo-600 dark:group-hover:border-indigo-400 pb-1"
                        >
                            {t("experience.download_cv")}
                        </span>
                        <svg
                            class="w-4 h-4 group-hover:translate-y-1 transition-transform"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </Container>
</section>
