<button
    id="theme-toggle"
    class="fixed bottom-8 left-8 z-50 w-12 h-12 rounded-full flex items-center justify-center transition-all duration-300 hover:scale-110 cursor-pointer mix-blend-difference bg-white text-black"
    aria-label="Toggle theme"
>
    <svg
        class="w-5 h-5 hidden dark:block"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
    >
        <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
        ></path>
    </svg>
    <svg
        class="w-5 h-5 dark:hidden"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
    >
        <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
        ></path>
    </svg>
</button>

<script>
    let cleanup: (() => void) | undefined;

    function setupThemeToggle() {
        const themeToggleBtn = document.getElementById("theme-toggle");
        if (!themeToggleBtn) return;

        const handleToggle = (e: Event) => {
            e.preventDefault();

            const isDark = document.documentElement.classList.contains("dark");

            const toggleTheme = () => {
                if (isDark) {
                    document.documentElement.classList.remove("dark");
                    localStorage.setItem("theme", "light");
                } else {
                    document.documentElement.classList.add("dark");
                    localStorage.setItem("theme", "dark");
                }
            };

            if (!document.startViewTransition) {
                toggleTheme();
                return;
            }
            const mouseEvent = e as MouseEvent;
            const x = mouseEvent.clientX;
            const y = mouseEvent.clientY;

            const endRadius = Math.hypot(
                Math.max(x, window.innerWidth - x),
                Math.max(y, window.innerHeight - y),
            );
            document.documentElement.classList.add("theme-transitioning");

            const transition = document.startViewTransition(toggleTheme);
            transition.ready.then(() => {
                const clipPath = [
                    `circle(0px at ${x}px ${y}px)`,
                    `circle(${endRadius}px at ${x}px ${y}px)`,
                ];

                document.documentElement.animate(
                    {
                        clipPath: clipPath,
                    },
                    {
                        duration: 500,
                        easing: "ease-in-out",
                        pseudoElement: "::view-transition-new(root)",
                    },
                );
            });

            transition.finished.finally(() => {
                document.documentElement.classList.remove(
                    "theme-transitioning",
                );
            });
        };

        themeToggleBtn.removeEventListener("click", handleToggle);
        themeToggleBtn.addEventListener("click", handleToggle);

        return () => {
            themeToggleBtn.removeEventListener("click", handleToggle);
        };
    }

    cleanup = setupThemeToggle();

    document.addEventListener("astro:after-swap", () => {
        if (cleanup) cleanup();
        cleanup = setupThemeToggle();
    });
</script>
