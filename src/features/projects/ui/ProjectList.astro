---
import { useTranslations, ui } from "@shared/i18n";

interface Props {
    lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as keyof typeof ui);
const projects = (ui[lang as keyof typeof ui] as any)[
    "projects.items"
] as any[];
---

<section id="projects" class="max-w-[1200px] mx-auto px-6 mb-48 @container">
    <h2
        class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-16 scroll-spy-title"
        data-section="projects"
    >
        {t("projects.label")}
    </h2>

    <div class="flex flex-col gap-24 relative">
        {
            projects.map((project: any, index: number) => (
                <article
                    class:list={[
                        "sticky-card rounded-3xl overflow-hidden border project-card-inner transition-colors",
                        project.colorClass === "bg-white"
                            ? "bg-white dark:bg-neutral-900"
                            : project.colorClass,
                        project.colorClass === "bg-white"
                            ? "border-gray-100 dark:border-neutral-800"
                            : project.borderColor,
                    ]}
                    style={`top: ${120 + index * 30}px; z-index: ${index + 1};`}
                >
                    <div class="grid grid-cols-1 @[64rem]:grid-cols-2 min-h-[500px]">
                        <div class="p-8 @[48rem]:p-12 flex flex-col justify-between relative z-10">
                            <div>
                                <span
                                    class:list={[
                                        "inline-block px-3 py-1 text-xs font-mono mb-6 uppercase",
                                        project.colorClass === "bg-white"
                                            ? "bg-black text-white dark:bg-white dark:text-black"
                                            : "bg-white text-black",
                                    ]}
                                >
                                    {project.type}
                                </span>
                                <h3
                                    class:list={[
                                        "text-4xl @[48rem]:text-5xl font-bold mb-4",
                                        project.colorClass === "bg-white"
                                            ? "text-neutral-900 dark:text-white"
                                            : "text-white",
                                    ]}
                                >
                                    {project.title}
                                </h3>
                                <p
                                    class:list={[
                                        "text-lg leading-relaxed mb-8",
                                        project.colorClass === "bg-white"
                                            ? "text-gray-600 dark:text-gray-400"
                                            : "text-gray-300",
                                        project.colorClass === "bg-indigo-600"
                                            ? "text-indigo-100"
                                            : "",
                                    ]}
                                >
                                    {project.description}
                                </p>
                                <div class="flex flex-wrap gap-2 mb-8">
                                    {project.tags.map((tag: string) => (
                                        <span
                                            class:list={[
                                                "px-3 py-1 rounded-full text-xs font-medium",
                                                project.colorClass ===
                                                "bg-white"
                                                    ? "bg-gray-100 dark:bg-neutral-800 dark:text-gray-300"
                                                    : "bg-gray-800 border border-gray-700 text-gray-300",
                                                project.colorClass ===
                                                "bg-indigo-600"
                                                    ? "bg-indigo-800 border border-indigo-500 text-indigo-200"
                                                    : "",
                                            ]}
                                        >
                                            {tag}
                                        </span>
                                    ))}
                                </div>
                            </div>
                            <a
                                href="#"
                                class:list={[
                                    "inline-flex items-center text-lg font-bold hover:gap-2 transition-all",
                                    project.colorClass === "bg-white"
                                        ? "text-neutral-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400"
                                        : "text-white",
                                ]}
                            >
                                {project.linkText} →
                            </a>
                        </div>
                        <div
                            class:list={[
                                "flex items-center justify-center p-8",
                                project.colorClass === "bg-white"
                                    ? "bg-gray-50 dark:bg-neutral-800/50"
                                    : project.iconBg,
                            ]}
                        >
                            <div class="text-9xl">{project.icon}</div>
                        </div>
                    </div>
                </article>
            ))
        }
    </div>
</section>

<style>
    .sticky-card {
        position: sticky;
        top: 120px;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
    }

    .project-card-inner {
        box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.05);
    }
</style>
