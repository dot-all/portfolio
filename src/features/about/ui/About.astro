---
import { useTranslations } from "../../../shared/i18n";

interface Props {
    lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as any);
---

<section id="about" class="max-w-[1200px] mx-auto px-6 mb-32">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
        <div class="md:col-span-4">
            <h2
                class="text-sm font-bold uppercase tracking-widest text-gray-400 sticky top-32"
            >
                {t("about.label")}
            </h2>
        </div>
        <div class="md:col-span-8">
            <p
                class="text-xl md:text-2xl leading-relaxed font-light text-gray-800 mb-8"
            >
                {t("about.p1")}
            </p>
            <p
                class="text-xl md:text-2xl leading-relaxed font-light text-gray-800"
                set:html={t("about.p2").replace(
                    /\*\*(.*?)\*\*/g,
                    "<strong>$1</strong>",
                )}
            />
        </div>
    </div>
</section>
