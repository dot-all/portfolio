---
import MainLayout from "@widgets/layout/ui/MainLayout.astro";
import Hero from "@features/hero/ui/Hero.astro";
import Skills from "@features/skills/ui/Skills.astro";
import ProjectList from "@features/projects/ui/ProjectList.astro";
import ExperienceList from "@features/experience/ui/ExperienceList.astro";
import Contact from "@features/contact/ui/Contact.astro";
import Blog from "@features/blog/ui/Blog.astro";
import { languages } from "@shared/i18n";
import { useTranslations } from "@shared/i18n";

export function getStaticPaths() {
    return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: "es" | "en" };
const t = useTranslations(lang);
---

<MainLayout lang={lang} description={t("hero.meta_description") as string}>
    <Hero lang={lang} />
    <ExperienceList lang={lang} />
    {/* <ProjectList lang={lang} /> */}
    <Skills lang={lang} />
    <Blog lang={lang} />
    <Contact lang={lang} />
</MainLayout>
