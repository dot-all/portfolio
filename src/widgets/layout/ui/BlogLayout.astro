---
import { languages, useTranslations } from "@shared/i18n";
import MainLayout from "./MainLayout.astro";

interface Props {
    lang: keyof typeof languages;
    title: string;
    description: string;
}

const { lang, title, description } = Astro.props;
const t = useTranslations(lang);
---

<MainLayout lang={lang} title={title} description={description}>
    <div class="swiss-container" transition:name="blog-content">
        <a href={`/${lang}/#blog`} class="back-link">
            ← {t("blog.back")}
        </a>
        <div class="meta">
            <p>
                <strong>{t("blog.published")}:</strong>
                {new Date().toLocaleDateString(lang)}
            </p>
        </div>

        <main class="prose">
            <h1>{title}</h1>
            <slot />
        </main>
    </div>
</MainLayout>

<style>
    .swiss-container {
        --grid-cols: 12;
        --grid-gap: 20px;
        --font-sans:
            "Inter", "Helvetica Neue", "Helvetica", "Arial", sans-serif;

        --bg-color: transparent;
        --text-color: #1a1a1a;
        --border-color: #000000;
        --muted-text: #666666;
        --code-bg: #1a1a1a;
        --code-text: #f4f4f4;
        --inline-code-bg: #e0e0e0;
        --inline-code-text: #1a1a1a;
        --blockquote-border: #000000;

        font-family: var(--font-sans);
        line-height: 1.4;
        width: 100%;
        max-width: 1440px;
        margin-left: auto;
        margin-right: auto;

        display: flex;
        flex-direction: column;
        padding: 20px;
        padding-top: 100px;

        background-color: var(--bg-color);
        color: var(--text-color);
        min-height: 100vh;
        transition:
            background-color 0.3s ease,
            color 0.3s ease;
    }

    :global(.dark) .swiss-container {
        --bg-color: #0a0a0a;
        --text-color: #e0e0e0;
        --border-color: #333333;
        --muted-text: #a0a0a0;
        --code-bg: #1f1f1f;
        --code-text: #e0e0e0;
        --inline-code-bg: #333333;
        --inline-code-text: #e0e0e0;
        --blockquote-border: #e0e0e0;
    }

    .swiss-container main {
        width: 100%;
        max-width: 65ch;
        margin: 0 auto;
    }

    h1 {
        font-size: 2.5rem;
        font-weight: 700;
        letter-spacing: -0.04em;
        line-height: 1.1;
        margin-bottom: 30px;
        color: var(--text-color);
    }

    .meta {
        width: 100%;
        max-width: 65ch;
        margin: 0 auto 40px auto;
        font-size: 0.875rem;
        padding-top: 10px;
        border-top: 1px solid var(--border-color);
        height: fit-content;
        color: var(--text-color);
        order: -1;
    }

    @media (min-width: 768px) {
        .swiss-container {
            display: grid;
            grid-template-columns: repeat(var(--grid-cols), 1fr);
            column-gap: var(--grid-gap);
            padding: 40px;
            padding-top: 120px;
        }

        .swiss-container main {
            grid-column: 4 / 10;
            max-width: none;
            margin: 0;
        }

        .meta {
            grid-column: 2 / 4;
            max-width: none;
            margin: 0;
            order: initial;
            border-top: 1px solid var(--border-color);
        }

        .back-link {
            grid-column: 2 / 4;
            margin-bottom: 20px;
            order: -1;
        }

        h1 {
            font-size: 4rem;
            margin-bottom: 40px;
        }
    }

    .back-link {
        display: inline-block;
        margin-bottom: 20px;
        font-weight: 500;
        text-decoration: none;
        color: var(--text-color);
        transition: opacity 0.2s ease;
        order: -2;
    }

    .back-link:hover {
        opacity: 0.6;
    }

    .prose {
    }

    .prose :global(h2),
    .prose :global(h3),
    .prose :global(h4) {
        color: var(--text-color);
    }

    .prose :global(h2) {
        font-size: 2.25rem;
        margin-top: 2.5em;
        margin-bottom: 0.8em;
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.2;
    }

    .prose :global(h3) {
        font-size: 1.75rem;
        margin-top: 2em;
        margin-bottom: 0.6em;
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.3;
    }

    .prose :global(h4) {
        font-size: 1.25rem;
        margin-top: 1.5em;
        margin-bottom: 0.5em;
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.4;
    }

    .prose :global(p) {
        font-size: 1.125rem;
        margin-bottom: 1.5em;
        color: var(--text-color);
    }

    .prose :global(ul),
    .prose :global(ol) {
        margin-bottom: 1.5em;
        padding-left: 1.5em;
        color: var(--text-color);
    }

    .prose :global(li) {
        margin-bottom: 0.5em;
    }

    .prose :global(strong) {
        font-weight: 700;
        color: var(--text-color);
    }

    .prose :global(blockquote) {
        border-left: 4px solid var(--blockquote-border);
        padding-left: 1.5em;
        margin-left: 0;
        font-style: italic;
        font-size: 1.25rem;
        color: var(--text-color);
    }

    .prose :global(pre) {
        background: var(--code-bg);
        color: var(--code-text);
        padding: 12px;
        border-radius: 4px;
        overflow-x: auto;
        margin-bottom: 2em;
        font-family: "Menlo", "Monaco", "Courier New", monospace;
        font-size: 0.8rem;
        border: 1px solid var(--border-color);
        max-width: 100%;
    }

    @media (min-width: 768px) {
        .prose :global(pre) {
            padding: 20px;
            font-size: 0.9rem;
        }
    }

    .prose :global(code) {
        font-family: "Menlo", "Monaco", "Courier New", monospace;
        background: var(--inline-code-bg);
        color: var(--inline-code-text);
        padding: 0.2em 0.4em;
        border-radius: 2px;
        font-size: 0.9em;
    }

    .prose :global(pre code) {
        background: transparent;
        color: inherit;
        padding: 0;
        border: none;
    }

    .prose :global(a) {
        color: var(--text-color);
        text-decoration: underline;
        text-underline-offset: 4px;
    }

    .prose :global(a:hover) {
        opacity: 0.8;
    }
</style>
