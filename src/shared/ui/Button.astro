---
interface Props {
    variant?: "primary" | "secondary";
    href?: string;
    class?: string;
    [key: string]: any;
}

const { variant = "primary", href, class: className, ...rest } = Astro.props;

const baseStyles =
    "px-6 py-2 rounded-lg font-medium transition-colors duration-200";
const variants = {
    primary: "bg-blue-600 text-white hover:bg-blue-700",
    secondary: "bg-gray-200 text-gray-800 hover:bg-gray-300",
};
---

{
    href ? (
        <a
            href={href}
            class:list={[baseStyles, variants[variant], className]}
            {...rest}
        >
            <slot />
        </a>
    ) : (
        <button
            class:list={[baseStyles, variants[variant], className]}
            {...rest}
        >
            <slot />
        </button>
    )
}
